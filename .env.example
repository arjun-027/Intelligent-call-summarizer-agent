# ── Groq API (required) ───────────────────────────────────────────────────────
# Obtain your key from https://console.groq.com/keys
# Model used: llama-3.1-8b-instant (6,000 tokens-per-minute rate limit)
GROQ_API_KEY=your_groq_api_key_here

# ── LangSmith Observability (optional) ───────────────────────────────────────
# Traces every LangGraph node (load → summarize → save) and all LLM calls so
# you can inspect inputs, outputs, latency, and token usage in the dashboard.
#
# Sign up at https://smith.langchain.com to get an API key.
# Two endpoint options:
#   EU data residency : https://eu.api.smith.langchain.com
#   US (default)      : https://api.smith.langchain.com
#
# Set LANGSMITH_TRACING=false to disable tracing without removing the other vars.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
# Project name shown in the LangSmith dashboard — use one name per environment.
LANGSMITH_PROJECT=Call summarizer agent
